# ArenaGo paper-trading platform (NO Bearer prefix!)
SANDBOX_API_KEY=your_arenago_key_here

# AlgoPack / MOEX ISS market data (Bearer JWT)
ALGOPACK_TOKEN=your_algopack_jwt_here

# polza.ai LLM API (Bearer token, base_url = https://polza.ai/api/v1)
POLZA_API_KEY=your_polza_key_here

# FRED API (free, register at fredaccount.stlouisfed.org)
FRED_API_KEY=your_fred_key_here

# EIA Open Data (free, register at eia.gov/opendata/register.php)
EIA_API_KEY=your_eia_key_here

# Marketaux (optional, 100 req/day free, for sentiment scoring)
MARKETAUX_API_KEY=your_marketaux_key_here

# Run mode: backtest | paper | live
RUN_MODE=backtest

# Bot name on ArenaGo
ARENAGO_BOT_NAME=MoexML_Bot

# Sizing mode: test (conservative) | live (full)
LIVE_SIZING=0

# Enable ops buttons in GitLab CI
ENABLE_OPS_BUTTONS=no
